{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run Summary v2 (SPEC 2.7) — every field: {value, confidence}",
  "definitions": {
    "tiered": {
      "type": "object",
      "required": ["value", "confidence"],
      "properties": {
        "value": {},
        "confidence": {"enum": ["authoritative", "derived", "proxy_observed", "unavailable"]}
      }
    }
  },
  "type": "object",
  "required": ["run_id", "task_id", "task_suite_version", "configuration_id",
               "manifest_ref", "identity", "usage", "behavior", "economics",
               "human_effort", "acceptance", "legs"],
  "properties": {
    "run_id": {"type": "string"},
    "task_id": {"type": "string"},
    "task_suite_version": {"type": "string"},
    "configuration_id": {"enum": ["C1", "C2", "C3", "C4", "C5", "P0", "P1"]},
    "manifest_ref": {"type": "string"},
    "hidden_test_hash": {"type": "string"},
    "identity": {
      "type": "object",
      "properties": {
        "product": {"$ref": "#/definitions/tiered"},
        "provider": {"$ref": "#/definitions/tiered"},
        "model_or_selector": {"$ref": "#/definitions/tiered"},
        "product_version": {"$ref": "#/definitions/tiered"},
        "auth_billing_path": {"$ref": "#/definitions/tiered"},
        "region": {"$ref": "#/definitions/tiered"},
        "reasoning_config": {"$ref": "#/definitions/tiered"},
        "permission_profile": {"$ref": "#/definitions/tiered"},
        "network_policy": {"$ref": "#/definitions/tiered"},
        "session_state": {"$ref": "#/definitions/tiered"},
        "cache_state": {"$ref": "#/definitions/tiered"}
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "input_tokens": {"$ref": "#/definitions/tiered"},
        "cache_creation_tokens": {"$ref": "#/definitions/tiered"},
        "cache_read_tokens": {"$ref": "#/definitions/tiered"},
        "output_tokens": {"$ref": "#/definitions/tiered"},
        "reasoning_tokens": {"$ref": "#/definitions/tiered"},
        "tool_result_tokens": {"$ref": "#/definitions/tiered"},
        "search_ops": {"$ref": "#/definitions/tiered"},
        "code_exec_usage": {"$ref": "#/definitions/tiered"}
      }
    },
    "behavior": {
      "type": "object",
      "properties": {
        "turns": {"$ref": "#/definitions/tiered"},
        "tool_calls_by_type": {"$ref": "#/definitions/tiered"},
        "file_reads": {"$ref": "#/definitions/tiered"},
        "files_modified": {"$ref": "#/definitions/tiered"},
        "retries": {"$ref": "#/definitions/tiered"},
        "escalations": {"$ref": "#/definitions/tiered"},
        "subagent_calls": {"$ref": "#/definitions/tiered"},
        "verifier_calls": {"$ref": "#/definitions/tiered"},
        "failures_by_category": {"$ref": "#/definitions/tiered"}
      }
    },
    "economics": {
      "type": "object",
      "required": ["cost_basis"],
      "properties": {
        "cost_basis": {"enum": ["marginal_api_cost", "allocated_subscription_cost",
                                 "provider_reported_cost", "cost_unavailable"]},
        "provider_cost_usd": {"$ref": "#/definitions/tiered"},
        "machine_cost_usd": {"$ref": "#/definitions/tiered"},
        "marginal_operating_usd": {"$ref": "#/definitions/tiered"},
        "fully_allocated_usd": {"$ref": "#/definitions/tiered"},
        "pricing_snapshot": {"type": "string"}
      }
    },
    "human_effort": {
      "type": "object",
      "properties": {
        "active_minutes": {"$ref": "#/definitions/tiered"},
        "review_minutes": {"$ref": "#/definitions/tiered"},
        "correction_minutes": {"$ref": "#/definitions/tiered"},
        "blocked_minutes": {"$ref": "#/definitions/tiered"}
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": {"enum": ["accepted", "rejected", "error"]},
        "gate_checks": {"type": "object"},
        "intention_to_route": {"type": ["string", "null"]},
        "completed_route": {"type": ["string", "null"]}
      }
    },
    "legs": {
      "description": "Billing legs; C5 has two (conductor, executor).",
      "type": "array",
      "items": {"type": "object"}
    },
    "wall_clock_seconds": {"$ref": "#/definitions/tiered"}
  }
}
